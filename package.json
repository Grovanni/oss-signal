{
  "name": "pr-signal",
  "version": "0.3.3",
  "description": "A deterministic PR intake brief for maintainers and coding agents.",
  "type": "module",
  "bin": {
    "pr-signal": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "schemas",
    "docs",
    "action.yml",
    "scripts/github-action",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check": "npm run build && npm run test && npm run lint"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "github",
    "pull-request",
    "review",
    "cli",
    "deterministic"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "commander": "^15.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
